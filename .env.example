# Twilio (required): programmable voice account.
# Find these at https://console.twilio.com under Account Info.
TWILIO_ACCOUNT_SID=ACyour-account-sid-here
TWILIO_AUTH_TOKEN=your-auth-token-here

# The phone number you purchase in Twilio for this agent to answer/call from,
# in E.164 format (e.g. +15551234567).
TWILIO_PHONE_NUMBER=+1your-twilio-number-here

# LLM for conversation logic: reuses the same Vertex AI / Gemini credential
# already used by trade-intelligence-copilot. Point this at your service
# account JSON's path on disk; never commit the real file.
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/vertex-service-account.json
GCP_PROJECT=your-gcp-project-id
GCP_LOCATION=global

# Optional, reserved for a future ASR upgrade: not wired into the code yet.
# Twilio's built-in <Gather> speech recognition is what's actually used
# today. Leave blank.
DEEPGRAM_API_KEY=

# Optional: only needed for real Google Calendar booking instead of the
# default local SQLite calendar store. Leave blank to use the local store.
GOOGLE_CALENDAR_CREDENTIALS_PATH=
# Calendar id to book into when the above is set (defaults to "primary").
GOOGLE_CALENDAR_ID=

# Optional: the public URL Twilio should fetch TwiML from (an ngrok tunnel,
# or a real deploy's URL). Required only for real inbound phone calls or the
# outbound test-call CLI; everything else in this project works without it.
# Leave blank for local development and testing.
PUBLIC_WEBHOOK_BASE_URL=

# Optional: override where the SQLite database file is written. Defaults to
# voice-agent/data/voice_agent.db. Mainly useful for tests or deployments
# that need the DB on a different volume.
VOICE_AGENT_DB_PATH=
